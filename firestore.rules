rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - name: string
    //   - email: string
    //   - role: string ('Administrador' | 'Capturista')
    //   - createdAt: string
    //
    // Collection: vouchers
    // Document ID: {voucherId}
    // Fields:
    //   - id: string
    //   - templateId: string
    //   - header: map
    //   - items: list
    //   - createdAt: string
    //   - createdBy: string
    //
    // Collection: customTemplates
    // Document ID: {templateId}
    // Fields:
    //   - id: string
    //   - concepto: string
    //   - subConcepto: string
    //   - items: list
    //
    // Collection: settings
    // Document ID: lists
    // Fields:
    //   - destajistas: list
    //   - elaboroList: list
    //   - autorizoList: list
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Administrador') ||
        (request.auth.token.email == "luciohernandez133@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "administracion@construvivienda.local") ||
        (request.auth.token.email == "admin_tsunami@construvivienda.local") ||
        (request.auth.token.email == "admin_tsunami2@construvivienda.local") ||
        (request.auth.token.email == "admin_tsunami3@construvivienda.local") ||
        (request.auth.token.email == "admin@construvivienda.local")
      );
    }

    function isCapturistaOrAdmin() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'Capturista')
      );
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['Administrador', 'Capturista'] &&
             data.createdAt is string;
    }

    function isValidVoucher(data) {
      return data.keys().hasAll(['id', 'templateId', 'header', 'items', 'createdAt', 'createdBy']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.templateId is string && data.templateId.size() > 0 && data.templateId.size() < 100 &&
             data.header is map &&
             data.items is list && data.items.size() <= 1000 &&
             data.createdAt is string &&
             data.createdBy is string;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['id', 'concepto', 'subConcepto', 'items']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.concepto is string && data.concepto.size() > 0 && data.concepto.size() < 200 &&
             data.subConcepto is string && data.subConcepto.size() < 200 &&
             data.items is list && data.items.size() <= 1000 &&
             (!('paquete' in data) || data.paquete is string) &&
             (!('prototipo' in data) || data.prototipo is string);
    }

    function isValidSettingsLists(data) {
      return data.keys().hasAll(['destajistas', 'elaboroList', 'autorizoList', 'packagesList', 'customLocations']) &&
             data.destajistas is list && data.destajistas.size() <= 2000 &&
             data.elaboroList is list && data.elaboroList.size() <= 2000 &&
             data.autorizoList is list && data.autorizoList.size() <= 2000 &&
             data.packagesList is list &&
             data.customLocations is map;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['id', 'paquete', 'ubicacion', 'concepto', 'material', 'unidad', 'cantidadPresupuesto', 'salidas', 'saldoTotal']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.paquete is string && data.paquete.size() < 200 &&
             data.ubicacion is string && data.ubicacion.size() < 200 &&
             data.concepto is string && data.concepto.size() < 200 &&
             data.material is string && data.material.size() < 200 &&
             data.unidad is string && data.unidad.size() < 100 &&
             data.cantidadPresupuesto is number &&
             data.salidas is number &&
             data.saldoTotal is number &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{email} {
      // Any authenticated user can read users (needed for UI to show names)
      allow read: if isAuthenticated();
      
      // Only admins can create/update users, OR the default admin can create themselves
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(email) && (request.auth.token.email == "luciohernandez133@gmail.com" || request.auth.token.email == "administracion@construvivienda.local" || request.auth.token.email == "admin_tsunami@construvivienda.local" || request.auth.token.email == "admin_tsunami2@construvivienda.local" || request.auth.token.email == "admin_tsunami3@construvivienda.local" || request.auth.token.email == "admin@construvivienda.local")));
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && isAdmin();
      allow delete: if isAdmin() && !isOwner(email); // Cannot delete self
    }

    match /vouchers/{voucherId} {
      allow read: if isCapturistaOrAdmin();
      allow create: if isCapturistaOrAdmin() && isValidVoucher(request.resource.data);
      allow update: if isCapturistaOrAdmin() && isValidVoucher(request.resource.data);
      allow delete: if isCapturistaOrAdmin();
    }

    match /customTemplates/{templateId} {
      allow read: if isCapturistaOrAdmin();
      allow create: if isAdmin() && isValidTemplate(request.resource.data);
      allow update: if isAdmin() && isValidTemplate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isCapturistaOrAdmin();
      allow create: if isAdmin() && docId == 'lists' && isValidSettingsLists(request.resource.data);
      allow update: if isAdmin() && docId == 'lists' && isValidSettingsLists(request.resource.data);
      allow delete: if false;
    }

    match /budgets/{budgetId} {
      allow read: if isCapturistaOrAdmin();
      allow create: if isAdmin() && isValidBudget(request.resource.data);
      allow update: if isCapturistaOrAdmin() && isValidBudget(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
